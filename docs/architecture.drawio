        <mxCell id="e10" edge="1" parent="1" source="b-auth" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#d6b656;fontColor=#7d6608;fontSize=10;" target="s-users" value="R/W token, status, role">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e11" edge="1" parent="1" source="b-ratelimit" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#d6b656;fontColor=#7d6608;fontSize=10;" target="s-ratelimit" value="R/W counts">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e12" edge="1" parent="1" source="b-data" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#d6b656;fontColor=#7d6608;fontSize=10;" target="s-requests" value="Check / log requestId">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e13" edge="1" parent="1" source="b-router" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#d6b656;fontColor=#7d6608;fontSize=10;" target="s-accesslog" value="logRequest() every call">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
