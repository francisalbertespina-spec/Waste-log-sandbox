  <diagram id="wms-architecture" name="WMS Architecture">
    <mxGraphModel dx="2037" dy="1110" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1900" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=20;fontStyle=1;fontColor=#1a1a2e;" value="Waste Management System — Architecture" vertex="1">
          <mxGeometry height="40" width="800" x="550" y="20" as="geometry" />
        </mxCell>
        <mxCell id="zone-client-bg" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;opacity=30;fontSize=12;" value="" vertex="1">
          <mxGeometry height="980" width="340" x="40" y="70" as="geometry" />
        </mxCell>
        <mxCell id="zone-client-label" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=top;whiteSpace=wrap;fontSize=13;fontStyle=1;fontColor=#23527c;" value="CLIENT (Browser / PWA)" vertex="1">
          <mxGeometry height="30" width="340" x="40" y="75" as="geometry" />
        </mxCell>
        <mxCell id="zone-backend-bg" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;opacity=30;" value="" vertex="1">
          <mxGeometry height="980" width="360" x="430" y="70" as="geometry" />
        </mxCell>
        <mxCell id="zone-backend-label" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=top;whiteSpace=wrap;fontSize=13;fontStyle=1;fontColor=#33691e;" value="BACKEND (Google Apps Script)" vertex="1">
          <mxGeometry height="30" width="360" x="430" y="75" as="geometry" />
        </mxCell>
        <mxCell id="zone-storage-bg" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;opacity=30;" value="" vertex="1">
          <mxGeometry height="980" width="360" x="840" y="70" as="geometry" />
        </mxCell>
        <mxCell id="zone-storage-label" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=top;whiteSpace=wrap;fontSize=13;fontStyle=1;fontColor=#7d6608;" value="GOOGLE WORKSPACE (Storage)" vertex="1">
          <mxGeometry height="30" width="360" x="840" y="75" as="geometry" />
        </mxCell>
        <mxCell id="zone-notif-bg" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;opacity=30;" value="" vertex="1">
          <mxGeometry height="980" width="280" x="1250" y="70" as="geometry" />
        </mxCell>
        <mxCell id="zone-notif-label" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=top;whiteSpace=wrap;fontSize=13;fontStyle=1;fontColor=#a52a2a;" value="NOTIFICATIONS" vertex="1">
          <mxGeometry height="30" width="280" x="1250" y="75" as="geometry" />
        </mxCell>
        <mxCell id="c-login" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=left;spacingLeft=10;verticalAlign=top;spacingTop=8;" value="🔐 Login Section&#xa;(index.html)&#xa;&#xa;• Enter email&#xa;• Google Sign-In button&#xa;• Status messages" vertex="1">
          <mxGeometry height="110" width="300" x="60" y="120" as="geometry" />
        </mxCell>
        <mxCell id="c-session" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=left;spacingLeft=10;verticalAlign=top;spacingTop=8;" value="🔑 Session Manager&#xa;(script.js)&#xa;&#xa;• localStorage: token, role, email, tokenExpiry&#xa;• Token refresh timer (30 min before expiry)&#xa;• validateSession() on every load&#xa;• handleSessionExpired() → clear &amp; redirect" vertex="1">
          <mxGeometry height="130" width="300" x="60" y="250" as="geometry" />
        </mxCell>
        <mxCell id="c-select" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=left;spacingLeft=10;verticalAlign=top;spacingTop=8;" value="📦 Package &amp; Waste Type Selection&#xa;&#xa;• P4 / P5 / P6 card selection&#xa;• Hazardous ☣️ / Solid 🗑️ toggle&#xa;• Breadcrumb navigation" vertex="1">
          <mxGeometry height="110" width="300" x="60" y="400" as="geometry" />
        </mxCell>
        <mxCell id="c-form" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=left;spacingLeft=10;verticalAlign=top;spacingTop=8;" value="📝 Waste Log Form&#xa;&#xa;Hazardous: date, volume (L), waste name, photo&#xa;Solid: date, dump location, waste name, photo&#xa;&#xa;• GPS stamp via Geolocation API (lat/lng on photo)&#xa;• Canvas watermark on photo (email + pkg + time + coords)&#xa;• Fingerprint dedup check before POST&#xa;• Submit → POST to Apps Script" vertex="1">
          <mxGeometry height="150" width="300" x="60" y="530" as="geometry" />
        </mxCell>
        <mxCell id="c-history" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=left;spacingLeft=10;verticalAlign=top;spacingTop=8;" value="📋 History &amp; Export&#xa;&#xa;• Date range filter (from / to)&#xa;• Fetch records from Apps Script&#xa;• Render table with photo preview modal&#xa;• Export to Excel (.xlsx) via SheetJS&#xa;• Export to PDF via jsPDF" vertex="1">
          <mxGeometry height="130" width="300" x="60" y="690" as="geometry" />
        </mxCell>
        <mxCell id="c-admin" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;align=left;spacingLeft=10;verticalAlign=top;spacingTop=8;" value="🛡️ Admin Dashboard (Admin+ only)&#xa;&#xa;• User Management: approve / reject / role / delete&#xa;• Analytics: KPIs, trend chart, breakdown,&#xa;  contributors, PDF export&#xa;• Request Logs&#xa;• Push notification bell + badge" vertex="1">
          <mxGeometry height="130" width="300" x="60" y="830" as="geometry" />
        </mxCell>
        <mxCell id="c-sw" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0e6ff;strokeColor=#7b4f9e;fontSize=11;align=left;spacingLeft=10;verticalAlign=top;spacingTop=8;" value="⚙️ Service Worker (sw.js)&#xa;&#xa;• Receives push events&#xa;• Shows system notifications&#xa;• Handles notification click actions&#xa;• Background sync hook" vertex="1">
          <mxGeometry height="110" width="300" x="60" y="980" as="geometry" />
        </mxCell>
        <mxCell id="b-router" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=left;spacingLeft=10;verticalAlign=top;spacingTop=8;" value="🔀 Request Router&#xa;(doGet / doPost)&#xa;&#xa;Dispatches by action= parameter:&#xa;• No action + email → login&#xa;• validateToken / refreshToken / logout&#xa;• getUsers / approveUser / rejectUser&#xa;• updateUserStatus / updateUserRole / deleteUser&#xa;• getRequests / checkUserSheet&#xa;• getImageBase64&#xa;• editEntry / deleteEntry → update or remove row&#xa;• package= → fetch records&#xa;• POST body → log waste entry" vertex="1">
          <mxGeometry height="210" width="320" x="450" y="120" as="geometry" />
        </mxCell>
        <mxCell id="b-auth" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=left;spacingLeft=10;verticalAlign=top;spacingTop=8;" value="🔐 Auth Module&#xa;&#xa;checkUser(email)&#xa;  → lookup or register user&#xa;  → issue UUID token + 7-day expiry&#xa;&#xa;validateUserToken(token)&#xa;  → match token, check expiry&#xa;&#xa;refreshToken(oldToken)&#xa;  → extend expiry 7 more days&#xa;&#xa;requireAdmin(token)&#xa;  → role must be admin/super_admin" vertex="1">
          <mxGeometry height="190" width="320" x="450" y="350" as="geometry" />
        </mxCell>
        <mxCell id="b-ratelimit" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=left;spacingLeft=10;verticalAlign=top;spacingTop=8;" value="⏱️ Rate Limiter&#xa;&#xa;checkRateLimit(email)&#xa;  → RateLimits sheet lookup&#xa;  → 100 req / hour per user&#xa;  → reset after 1-hour window&#xa;  → returns true/false" vertex="1">
          <mxGeometry height="130" width="320" x="450" y="560" as="geometry" />
        </mxCell>
        <mxCell id="b-usermgr" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=left;spacingLeft=10;verticalAlign=top;spacingTop=8;" value="👥 User Manager (Admin+)&#xa;&#xa;getUsersSecure(token)&#xa;updateUserStatusSecure(token, email, status)&#xa;updateUserRoleSecure(token, email, role)&#xa;deleteUserSecure(token, email)&#xa;&#xa;Super Admin only: role changes, deletes&#xa;Admin: approve/reject pending only" vertex="1">
          <mxGeometry height="150" width="320" x="450" y="710" as="geometry" />
        </mxCell>
        <mxCell id="b-data" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=left;spacingLeft=10;verticalAlign=top;spacingTop=8;" value="📊 Data Layer&#xa;&#xa;fetchEntries(pkg, user, from, to, wasteType)&#xa;  → selects PACKAGE_MAP or SOLID_PACKAGE_MAP&#xa;  → opens correct sheet&#xa;  → filters by package + date range&#xa;  → returns [headers, ...rows]&#xa;&#xa;editEntry(pkg, wasteType, rowIndex, fields)&#xa;  → updates row in-place on sheet&#xa;&#xa;deleteEntry(pkg, wasteType, rowIndex)&#xa;  → removes row from sheet&#xa;&#xa;doPost → validates fields → uploads photo&#xa;  → appends row with timestamp" vertex="1">
          <mxGeometry height="240" width="310" x="450" y="880" as="geometry" />
        </mxCell>
        <mxCell id="s-users" parent="1" style="shape=mxgraph.flowchart.document;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=8;verticalAlign=top;spacingTop=8;" value="📄 Google Sheet: Users&#xa;(USER_SHEET_ID)&#xa;&#xa;Cols: Email | Status | Token |&#xa;Last Login | Role | Token Expiry&#xa;&#xa;Status: Pending / Approved / Rejected&#xa;Role: user / admin / super_admin" vertex="1">
          <mxGeometry height="140" width="300" x="860" y="120" as="geometry" />
        </mxCell>
        <mxCell id="s-ratelimit" parent="1" style="shape=mxgraph.flowchart.document;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=8;verticalAlign=top;spacingTop=8;" value="📄 Google Sheet: RateLimits&#xa;&#xa;Cols: Email | Count | Window Start&#xa;&#xa;Resets per 1-hour sliding window&#xa;Max: 100 requests / hour" vertex="1">
          <mxGeometry height="120" width="300" x="860" y="280" as="geometry" />
        </mxCell>
        <mxCell id="s-requests" parent="1" style="shape=mxgraph.flowchart.document;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=8;verticalAlign=top;spacingTop=8;" value="📄 Google Sheet: Requests&#xa;(Idempotency Log)&#xa;&#xa;Cols: requestId | timestamp&#xa;&#xa;Prevents duplicate POST submissions&#xa;requestId = fingerprint + date" vertex="1">
          <mxGeometry height="130" width="300" x="860" y="420" as="geometry" />
        </mxCell>
        <mxCell id="s-accesslog" parent="1" style="shape=mxgraph.flowchart.document;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=8;verticalAlign=top;spacingTop=8;" value="📄 Google Sheet: Access_Log&#xa;(Audit Trail)&#xa;&#xa;Cols: Timestamp | Action | Email |&#xa;Success | IP&#xa;&#xa;Every API call is logged here" vertex="1">
          <mxGeometry height="130" width="300" x="860" y="570" as="geometry" />
        </mxCell>
        <mxCell id="s-hazsheets" parent="1" style="shape=mxgraph.flowchart.document;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;align=left;spacingLeft=8;verticalAlign=top;spacingTop=8;" value="📄 Google Sheets: Hazardous Waste&#xa;(PACKAGE_MAP)&#xa;&#xa;P4: separate sheet + Drive folder&#xa;P5: separate sheet + Drive folder&#xa;P6: separate sheet + Drive folder&#xa;&#xa;Cols: date | volume | waste name |&#xa;package | logged by | photo | timestamp" vertex="1">
          <mxGeometry height="170" width="300" x="860" y="720" as="geometry" />
        </mxCell>
        <mxCell id="s-solidsheets" parent="1" style="shape=mxgraph.flowchart.document;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;align=left;spacingLeft=8;verticalAlign=top;spacingTop=8;" value="📄 Google Sheets: Solid Waste&#xa;(SOLID_PACKAGE_MAP)&#xa;&#xa;P4: separate sheet + Drive folder&#xa;P5: separate sheet + Drive folder&#xa;P6: separate sheet + Drive folder&#xa;&#xa;Cols: date | location | waste name |&#xa;package | logged by | photo | timestamp" vertex="1">
          <mxGeometry height="170" width="300" x="860" y="910" as="geometry" />
        </mxCell>
        <mxCell id="n-gmail" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;align=left;spacingLeft=8;verticalAlign=top;spacingTop=8;" value="📧 Gmail / MailApp&#xa;&#xa;sendStatusNotification()&#xa;  → Approval email to user&#xa;  → Rejection email to user&#xa;&#xa;notifySuperAdminsOfNewUser()&#xa;  → Alert all super_admins&#xa;    on new registration" vertex="1">
          <mxGeometry height="180" width="240" x="1270" y="120" as="geometry" />
        </mxCell>
        <mxCell id="n-push" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;align=left;spacingLeft=8;verticalAlign=top;spacingTop=8;" value="🔔 Push Notifications&#xa;(Browser / Service Worker)&#xa;&#xa;• Admin enables permission&#xa;• Poll every 2 min for pending users&#xa;• count increased → showNotification()&#xa;• Actions: [Review Now] [Later]&#xa;• Click → navigate to User Mgmt" vertex="1">
          <mxGeometry height="180" width="240" x="1270" y="320" as="geometry" />
        </mxCell>
        <mxCell id="n-drive" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=8;verticalAlign=top;spacingTop=8;" value="📁 Google Drive&#xa;(Photo Storage)&#xa;&#xa;Per-package folders:&#xa;• Hazardous P4 / P5 / P6&#xa;• Solid P4 / P5 / P6&#xa;&#xa;Files: JPEG with canvas watermark&#xa;Access: via getImageBase64()" vertex="1">
          <mxGeometry height="180" width="240" x="1270" y="520" as="geometry" />
        </mxCell>
        <mxCell id="n-libs" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6d0de;strokeColor=#ae4132;fontSize=11;align=left;spacingLeft=8;verticalAlign=top;spacingTop=8;" value="📦 External Libraries (CDN)&#xa;&#xa;• Chart.js — analytics charts&#xa;• jsPDF — PDF export&#xa;• SheetJS (xlsx) — Excel export&#xa;• Canvas API (built-in) — watermark" vertex="1">
          <mxGeometry height="150" width="240" x="1270" y="720" as="geometry" />
        </mxCell>
        <mxCell id="e1" edge="1" parent="1" source="c-login" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#6c8ebf;fontColor=#23527c;fontSize=10;" target="b-router" value="GET ?email=">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
