        </mxCell>
        <mxCell id="e17" edge="1" parent="1" source="b-usermgr" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#b85450;fontColor=#a52a2a;fontSize=10;" target="n-gmail" value="MailApp.sendEmail()">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
