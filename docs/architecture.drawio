          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e4" edge="1" parent="1" source="c-history" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#6c8ebf;fontColor=#23527c;fontSize=10;" target="b-router" value="GET ?package=&amp;wasteType=&#xa;&amp;from=&amp;to=">
